################CHAP 4.9-1 FRUITFUL FUNCTIONS - RETURN  VALUES
#area using a fruitful function 
import math

def area(radius):
    b = math.pi * radius **2
    return b



###function composition 
###writing a function inside of another functiion 

Suppose we want to write a function that calculates the area of a circle
We know the area of a circle is PI*r**2   loosely translated as pi * radius squared
we can begin by writing a distance function 
then we can use that function inside the 


#distance function 
we have this as the square root of sqrd(x2-x1) = sqrd(y2-y1)
we use this as the radius

def distance(x1 ,y1, x2, y2): 
    dx = x2 - x1
    dy = y2 - y1
    dsquared = dx**2 + dy**2
    result = dsquared**0.5
    return result

###recall area function
def area(radius):
    b = math.pi * radius **2
    return b

###now we create a radius variable 
radius = distance ( x1, y1, x2, y2)

###now we can do this
result = area(radius)
return result 

###which we combine below to do the following 

#area of circle function 
def areaCircle(x1, y1, x2, y2): 
    radius = distance ( x1, y1, x2, y2)
    result = area(radius)
    return result



#can implement this better or more compositionally as  
def areaOfCircle(x1,y1,x2,y2):
    return area(distance(x1,y1,x2,y2)







#Lets redo the compound interest formula

def final_amount (p, r, n, t):
    #Apply the compound interest formula to p
    #to produce the final amount

    a = p * ( 1+r/n) ** (n*t)
    return a					#This is new, and makes the function fruitful 

# now that we have the function above, let us call it
toInvest = float(input('How much do you want to invest? '))
fnl = final_amount(toInvest, .08, 12, 5)
print('At the end of the period you will have', fnl)


