Exercise 2
Write a program to draw concentric squares starting from a smaller to larger and larger



#pseudo code
#lets draw a function to draw a square
##the first square has size twenty 
###increase the size for the next square to 40 and so on


import turtle

#write the move down and left function

def startChange(animal):
    animal.penup()
    animal.right(90)
    animal.forward(10)
    animal.right(90)
    animal.forward(10)
    animal.right(180)
    animal.pendown()

#write the square function
def drawSquare( animal, lengthSide, degTurn):

    for _ in range(4): 
       animal.forward(lengthSide)
       animal.left(degTurn)


#setup window environment
window = turtle.Screen()		#set up window and attributes
window.bgcolor('lightgreen')
window.title('increasing concentric squares')

alex = turtle.Turtle()
alex.shape('turtle')
size = 20				#sides length initially 20 but we will increase them as we go on

#loop to include changing size
for _ in range(4):
    drawSquare(alex, size, 90)
    startChange(alex)
    size += 20

window.mainloop()





