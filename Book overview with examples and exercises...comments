##Recall we have to get the point code added 

def main():
    class Point: 
        """ Create a new point, at coordinates x, y """

    def __init__(self, x = 0, y = 0): 
        """ Create a new point at x, y, """
        self.x = x				#access the variable [self.x] then assign something to the variable
        self.y = y

    def distance_from_origin(self):
        """ compute my distance from the origin """
        return ((self.x ** 2) + (self.y ** 2)) ** 0.5   

    def to_string(self): 
       return "({0}, {1})".format(self.x, self.y)
    
    def halfway(self, target):
        """ Return the halfway point between myself and teh target """
        mx = (self.x + target.x) / 2
        my = (self.y + self.y) / 2
        return Point (mx, my)



class Rectangle: 
    """ A class to manufacture rectangle objects """

    def __init__(self, posn, w, h):
        """ Initializes rectangle at posn, with width w, heigh h """
        self. corner = posn
        self.width = w
        self.height = h

    def __str__(self): 
        return "({0}, {1}, {2})".format(self.corner, self.width, self.height)

    #add methods below to change the size of the rectangle and to move the rectangle
    def grow(self, delta_width, delta_height):
        """ Grow (or Shrink) this object by the deltas """
        self.width += delta_width
        self.height += delta_height


    def move(self, dx, dy)
        """ Move this object by the deltas """
        self.corner.x += dx 
        self.corner.y += dy


