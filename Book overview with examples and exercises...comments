pseudo:
for every letter in word: 
    reverse ordering of index
    i.e. take letter at index n-1 and create a new string with it at index 0
    repeat at n - 2 and concatenate with prior word

rand_word = "minerva"
new_string = ""
#size = len(rand_word)
#last = rand_word(size -1)

for i in range(len(rand_word)):
    i-1 += new_string
