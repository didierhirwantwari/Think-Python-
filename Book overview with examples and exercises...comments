pseudocode: 
take string 
cut the string 
find the item of interest
change the item of interest
join the new string 

print the new string





def replace(s, old, new): 

''' split the string '''
    s = s.split()
    #find the character of interest
    old = s.find("old")

    #perform the switch __ use temp variable
    for h in s: 
        temp = old
        old = new
        new = temp

    #join the new string
    s = s.join

print(s)
    
    

