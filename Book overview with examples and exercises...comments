## Tuples as return values
can return multiple values for example mean and standard deviation

import math

def circle_stats(r): 
    '''Return (circumference, area) of a circle of radius r '''
    circumference = 2 * math.pi * r
    area = math.pi * r * r
    return (circumference, "{0:.3f}".format(area))  


