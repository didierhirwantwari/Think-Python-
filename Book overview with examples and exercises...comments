    @classmethodsd
    def allowed_titles_starting_with(cls, startswith):
        #class or instance object accissble through cls
        return [t for t in cls.TITLES if t.startswith(startswith)]

    @staticmethod
    def allowed_titles_ending_with(endswith):         #class method
        #no param for class or instance object
	#we have to use Person directly 
