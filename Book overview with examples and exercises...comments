7 ax = fig.add_subplot(1, 1, 1)
8 ax.plot([0.1, 0.2, 0.3, 0.4], [1, 2, 3, 4])
9 ax.plot([0.1, 0.2, 0.3, 0.4], [1, 4, 9, 16])
10 ax.set_xlabel('Time (s)')
11 ax.set_ylabel('Scale (Bananas)')
12
13 plt.show()


